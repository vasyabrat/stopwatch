{
  "rules": {
    "games": {
      "$code": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },
    "roles": {
      "$code": {
        ".write": "auth != null",
        "$uid": {
          ".read": "auth != null && auth.uid == $uid"
        }
      }
    },
    "lobbies": {
      ".read": "auth != null",
      ".write": "auth != null"
    }
  }
}
